# API base URL (백엔드: syakBE)
# 개발 기본값. Android 에뮬레이터에서는 localhost 대신 10.0.2.2 사용.
EXPO_PUBLIC_API_URL=http://localhost:3000/api/v1

# 소셜 로그인 키 (네이티브 모듈 — dev build에서만 동작). 값을 채우면 해당 plugin/SDK가 활성화된다.
# 키가 없으면 코드가 조건부로 통과하므로 web/Expo Go에선 비워둬도 된다. 자세한 발급은 docs/dev-build.md.

# 카카오 (네이티브 앱 키 — 앱에 박히는 공개키, 비밀값 아님)
# EXPO_PUBLIC_KAKAO_NATIVE_APP_KEY=

# 네이버 (네이버 개발자센터 발급). consumerSecret은 SDK 요구로 앱에 박힘(네이버 SDK 설계상 불가피).
# EXPO_PUBLIC_NAVER_CONSUMER_KEY=
# EXPO_PUBLIC_NAVER_CONSUMER_SECRET=
# EXPO_PUBLIC_NAVER_APP_NAME=syak
# EXPO_PUBLIC_NAVER_URL_SCHEME=          # iOS 콜백용 URL scheme (예: naverLogin)

# 네이버 지도 (NCP 발급 — console.ncloud.com Maps, 로그인 키와 별개). 없으면 지도 placeholder.
# EXPO_PUBLIC_NAVER_MAP_CLIENT_ID=
